# ──────────────────────────────────────────────────────────────────────────────
# Cyber Threat Prioritization Agent — frontend environment variables
#
# HOW TO USE:
#   1. Copy this file to .env.local in the same directory
#   2. Replace the placeholder URL with your actual Render backend URL
#   3. Do NOT commit .env.local — it is gitignored
#
# VERCEL DEPLOYMENT:
#   Project Settings → Environment Variables → Add:
#     Name:  NEXT_PUBLIC_API_URL
#     Value: https://<your-render-service-name>.onrender.com
#   After adding, trigger a new deployment (Vercel bakes env vars at build time).
#
# LOCAL DEVELOPMENT:
#   NEXT_PUBLIC_API_URL can be omitted in .env.local for local dev —
#   api.ts will automatically fall back to http://localhost:8000.
# ──────────────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_API_URL=https://your-render-service-name.onrender.com
